{
    "name": "@exam-timetable/ui",
    "type": "module",
    "version": "0.0.1",
    "keywords": [
        "svelte"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "svelte": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js"
        },
        "./theme.css": "./dist/theme.css",
        "./reset.css": "./dist/reset.css"
    },
    "types": "./dist/index.d.ts",
    "files": [
        "!dist/**/*.spec.*",
        "!dist/**/*.test.*",
        "dist"
    ],
    "scripts": {
        "build": "vite build && npm run prepack",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "prepack": "svelte-kit sync && svelte-package && publint",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
    },
    "peerDependencies": {
        "svelte": "^5.0.0"
    },
    "dependencies": {
        "@fontsource-variable/google-sans-flex": "^5.2.3",
        "@js-temporal/polyfill": "^0.5.1",
        "@ktibow/iconset-material-symbols": "^0.0.1764827375",
        "@tanstack/svelte-form": "^1.29.1",
        "m3-svelte": "^7.1.2"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.1.2",
        "@eslint/js": "^10.0.1",
        "@exam-timetable/eslint-config": "workspace:*",
        "@iconify/types": "^2.0.0",
        "@storybook/addon-a11y": "^10.3.6",
        "@storybook/addon-docs": "^10.3.6",
        "@storybook/addon-svelte-csf": "^5.1.2",
        "@storybook/addon-vitest": "^10.3.6",
        "@storybook/sveltekit": "^10.3.6",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/kit": "^2.59.0",
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/node": "^25.6.0",
        "@typescript/native-preview": "7.0.0-dev.20260502.1",
        "@vitest/browser-playwright": "^4.1.5",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^10.3.0",
        "eslint-plugin-storybook": "^10.3.6",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^17.6.0",
        "playwright": "^1.59.1",
        "publint": "^0.3.18",
        "storybook": "^10.3.6",
        "svelte": "^5.55.5",
        "svelte-check": "^4.4.7",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^8.0.10",
        "vite-plugin-devtools-json": "^1.0.0",
        "vite-plugin-functions-mixins": "^0.4.1",
        "vite-plugin-token-shaker": "^0.0.7",
        "vitest": "^4.1.5"
    }
}
